{
  "datetime": {
    "command": "uvx",
    "args": [
      "fastmcp",
      "run",
      "./_mcp_servers/datetime-mcp/datetime-mcp.py"
    ]
  },
  "fetch": {
    "command": "uvx",
    "args": [
      "fastmcp",
      "run",
      "./_mcp_servers/fetch-mcp/fetch-mcp.py"
    ]
  },
  "filesystem": {
    "command": "uvx",
    "args": [
      "fastmcp",
      "run",
      "./_mcp_servers/filesystem-mcp/filesystem-mcp.py",
      "--",
      "./_test/filesystem"
    ]
  }
}
